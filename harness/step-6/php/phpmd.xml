<?xml version="1.0"?>
<ruleset name="kata-quality"
    xmlns="http://pmd.sf.net/ruleset/1.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
    xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>Kata quality rules — mirrors the Python flake8 thresholds.</description>

    <!-- Flag methods with cyclomatic complexity > 13 (base processLine=10, feature adds ~3 branches) -->
    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="14"/>
        </properties>
    </rule>

    <!-- Flag methods longer than 94 lines (base processLine=92, feature naively extends it) -->
    <rule ref="rulesets/codesize.xml/ExcessiveMethodLength">
        <properties>
            <property name="minimum" value="95"/>
        </properties>
    </rule>

    <!-- Flag classes longer than 219 lines (base=214, feature naively extends it) -->
    <rule ref="rulesets/codesize.xml/ExcessiveClassLength">
        <properties>
            <property name="minimum" value="220"/>
        </properties>
    </rule>

    <!-- Flag classes with more than 9 fields (base=9, feature adds reservation fields) -->
    <rule ref="rulesets/codesize.xml/TooManyFields">
        <properties>
            <property name="maxfields" value="9"/>
        </properties>
    </rule>

    <!-- Flag methods with more than 4 parameters -->
    <rule ref="rulesets/codesize.xml/ExcessiveParameterList">
        <properties>
            <property name="minimum" value="5"/>
        </properties>
    </rule>

</ruleset>
